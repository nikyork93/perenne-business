# ═══════════════════════════════════════════════════════════════
# PERENNE BUSINESS — Environment variables
# Copy to .env.local and fill with real values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ─────────────────────────────────
# Get from neon.tech console → Connection string (pooled)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
# Direct URL (non-pooled) for Prisma migrations
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ── Auth ────────────────────────────────────────────────────────
# Used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Base URL of the app (used in magic link emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email provider (Resend) ────────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=""
EMAIL_FROM="Perenne Business <business@perenne.app>"

# ── Stripe ─────────────────────────────────────────────────────
# Test keys from stripe.com → Developers → API keys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Cloudflare (for R2 uploads via Worker) ─────────────────────
# API calls from Next.js → perenne-api worker
PERENNE_API_URL="https://api.perenne.app"
# Shared secret for server-to-server calls between portal and worker
PERENNE_API_SECRET=""

# ── Super-admin ────────────────────────────────────────────────
# Email hardcoded as superadmin at DB seed
SUPERADMIN_EMAIL="nicholas@perenne.app"
